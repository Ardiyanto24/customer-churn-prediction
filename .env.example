# =============================================================================
# .ENV.EXAMPLE - Project Template
# =============================================================================
# PERHATIAN: File ini adalah template dan TIDAK BOLEH berisi nilai nyata (secrets).
#
# INSTRUKSI:
# 1. Salin file ini dan ubah namanya menjadi '.env' di root project.
# 2. Isi nilai variabel di dalam file '.env' tersebut sebelum menjalankan aplikasi.
# =============================================================================

# --- Weights & Biases (WandB) ---
# Ambil API Key Anda dari https://wandb.ai/settings
WANDB_API_KEY=your_api_key_here
WANDB_PROJECT=customer-churn-prediction
# Nama username atau team Anda di WandB (opsional)
WANDB_ENTITY=your_username_or_team

# --- Model Paths ---
# Jalur penyimpanan file artifact model dan preprocessor
MODEL_PATH=models/artifacts/model_final.joblib
PREPROCESSOR_PATH=models/artifacts/preprocessor.joblib

# --- API Server ---
# Konfigurasi host dan port untuk menjalankan FastAPI / API Server
API_HOST=0.0.0.0
API_PORT=8000

# --- Streamlit (Deployment Only) ---
# Diisi dengan URL publik Space API di Hugging Face.
# Contoh: https://username-tccp-api.hf.space
# Variabel ini hanya digunakan di environment deployment.
# Tidak diperlukan jika API dan UI dijalankan di mesin lokal yang sama.
API_BASE_URL=https://your-huggingface-space-url.hf.space